# BLS API key (optional - get one free at https://www.bls.gov/developers/)
# Without a key: 25 queries/day. With a key: 500 queries/day.
BLS_API_KEY=

# Crunchbase API key (paid - future use)
# CRUNCHBASE_API_KEY=

# CB Insights API key (enterprise - future use)
# CB_INSIGHTS_API_KEY=

# Database path (relative to project root)
DATABASE_PATH=data/startup_research.db

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
