# BLS API key (optional - get one free at https://www.bls.gov/developers/)
# Without a key: 25 queries/day. With a key: 500 queries/day.
BLS_API_KEY=

# Crunchbase API key (paid - future use)
# CRUNCHBASE_API_KEY=

# CB Insights API key (enterprise - future use)
# CB_INSIGHTS_API_KEY=

# MySQL database connection
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=startup_research

# JWT Authentication (REQUIRED for production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# GitHub Integration (optional - needed for git publisher agent)
# GITHUB_TOKEN=
# GITHUB_REPO=

# Redis (optional - caching and pub/sub)
# REDIS_URL=redis://localhost:6379/0

# Qdrant Vector Search (optional - semantic search)
# QDRANT_URL=http://localhost:6333

# Elasticsearch (optional - full-text search)
# ELASTICSEARCH_URL=http://localhost:9200

# TimescaleDB (optional - time-series data)
# TIMESCALEDB_URL=postgresql://startup:CHANGEME@localhost:5433/startup_timeseries

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
