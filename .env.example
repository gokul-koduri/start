# ── Required Secrets ──────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# MySQL database password (REQUIRED)
MYSQL_PASSWORD=

# JWT Authentication secret (REQUIRED for production)
JWT_SECRET=

# TimescaleDB password (REQUIRED if using time-series features)
TIMESCALEDB_PASSWORD=

# ── API Keys (optional) ──────────────────────────────────────

# BLS API key (optional - get one free at https://www.bls.gov/developers/)
# Without a key: 25 queries/day. With a key: 500 queries/day.
BLS_API_KEY=

# Crunchbase API key (paid - future use)
# CRUNCHBASE_API_KEY=

# CB Insights API key (enterprise - future use)
# CB_INSIGHTS_API_KEY=

# ── Database Connection ──────────────────────────────────────

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_DATABASE=startup_research

# ── CORS Origin ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── GitHub Integration (optional) ───────────────────────────
# GITHUB_TOKEN=
# GITHUB_REPO=

# ── External Services (optional) ────────────────────────────
# Redis (caching and pub/sub)
# REDIS_URL=redis://localhost:6379/0

# Qdrant Vector Search (semantic search)
# QDRANT_URL=http://localhost:6333

# Elasticsearch (full-text search)
# ELASTICSEARCH_URL=http://localhost:9200

# TimescaleDB (time-series data)
# TIMESCALEDB_URL=postgresql://startup:CHANGEME@localhost:5433/startup_timeseries

# ── SMTP (for email_worker — drains the outbound_emails queue) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com
#
# Providers:
#   Gmail:     smtp.gmail.com:587 (use App Password)
#   SendGrid:  smtp.sendgrid.net:587 (user=apikey, password=SG.XXX)
#   Mailgun:   smtp.mailgun.org:587
#   Amazon SES: email-smtp.region.amazonaws.com:587

# ── Webhooks (optional - for Slack/Discord alerts) ──────────
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
# CUSTOM_WEBHOOK_URL=

# ── Reverse Proxy (optional - for Caddy HTTPS) ──────────────
# DOMAIN=localhost
# CADDY_EMAIL=

# ── Stripe Payments (optional - for licensing) ──────────────
# STRIPE_SECRET_KEY=
# STRIPE_PRO_URL=

# ── Misc ─────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
